generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum TipoUsuario {
  admin
  contador
  assistente
}

enum PlanoTipo {
  essencial
  profissional
  empresarial
  startup
}

enum FormaPagamento {
  pix
  boleto
  cartao
}

enum StatusLead {
  iniciado
  simulador
  plano_escolhido
  dados_preenchidos
  socios_preenchidos
  revisao
  contrato_gerado
  aguardando_assinatura
  assinado
  expirado
  cancelado
}

enum StatusCliente {
  ativo
  inadimplente
  suspenso
  cancelado
  encerrado
}

enum StatusContrato {
  rascunho
  enviado
  aguardando_assinatura
  parcialmente_assinado
  assinado
  cancelado
  expirado
}

enum Regime {
  MEI
  SimplesNacional
  LucroPresumido
  LucroReal
  Autonomo
}

enum Prioridade {
  baixa
  media
  alta
  urgente
}

enum StatusTarefa {
  pendente
  em_andamento
  aguardando_cliente
  concluida
  cancelada
}

enum Canal {
  site
  whatsapp
  indicacao
  instagram
  google
  outro
}

enum TipoInteracao {
  whatsapp_enviado
  email_enviado
  email_recebido
  ligacao
  nota_interna
  status_mudou
  contrato_gerado
  contrato_assinado
  documento_enviado
  tarefa_criada
  cliente_ativado
  ia_escalada
  humano_respondeu
}

enum StatusEscalacao {
  pendente
  em_atendimento
  resolvida
}

enum CanalEscalacao {
  whatsapp
  onboarding
}

enum StatusMensagem {
  pending
  sent
  failed
}

model Usuario {
  id                 String      @id @default(uuid())
  nome               String
  email              String      @unique
  senhaHash          String
  tipo               TipoUsuario @default(assistente)
  ativo              Boolean     @default(true)
  precisaTrocarSenha Boolean     @default(false)
  avatar             String?
  criadoEm           DateTime    @default(now())
  atualizadoEm       DateTime    @updatedAt

  leadsResponsavel    Lead[]        @relation("LeadResponsavel")
  clientesResponsavel Cliente[]     @relation("ClienteResponsavel")
  tarefas             Tarefa[]      @relation("TarefaResponsavel")
  interacoes          Interacao[]
  notificacoes        Notificacao[]

  @@map("usuarios")
}

model Plano {
  id          String    @id @default(uuid())
  tipo        PlanoTipo @unique
  nome        String
  descricao   String?
  valorMinimo Decimal   @db.Decimal(10, 2)
  valorMaximo Decimal   @db.Decimal(10, 2)
  servicos    Json?
  destaque    Boolean   @default(false)
  ativo       Boolean   @default(true)
  criadoEm    DateTime  @default(now())

  @@map("planos")
}

model Lead {
  id             String          @id @default(uuid())
  contatoEntrada String
  canal          Canal           @default(site)
  funil          String          @default("onboarding")
  status         StatusLead      @default(iniciado)
  stepAtual      Int             @default(1)
  planoTipo      PlanoTipo?
  valorNegociado Decimal?        @db.Decimal(10, 2)
  vencimentoDia  Int?
  formaPagamento FormaPagamento?
  dadosJson      Json?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  responsavelId  String?
  responsavel    Usuario?        @relation("LeadResponsavel", fields: [responsavelId], references: [id])
  observacoes    String?         @db.Text
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt
  expiradoEm    DateTime?

  contrato   Contrato?
  documentos Documento[]
  interacoes Interacao[]
  cliente    Cliente?
  conversas  ConversaIA[]

  @@map("leads")
}

model Cliente {
  id                  String          @id @default(uuid())
  leadId              String?         @unique
  lead                Lead?           @relation(fields: [leadId], references: [id])
  nome                String
  cpf                 String          @unique
  rg                  String?
  dataNascimento      DateTime?
  estadoCivil         String?
  profissao           String?
  nacionalidade       String?         @default("Brasileiro(a)")
  email               String          @unique
  telefone            String
  whatsapp            String?
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?
  cnpj                String?         @unique
  razaoSocial         String?
  nomeFantasia        String?
  regime              Regime?
  planoTipo           PlanoTipo
  valorMensal         Decimal         @db.Decimal(10, 2)
  vencimentoDia       Int
  formaPagamento      FormaPagamento
  status              StatusCliente   @default(ativo)
  responsavelId       String?
  responsavel         Usuario?        @relation("ClienteResponsavel", fields: [responsavelId], references: [id])
  observacoesInternas String?         @db.Text
  tags                Json?
  dataInicio          DateTime?
  criadoEm            DateTime        @default(now())
  atualizadoEm        DateTime        @updatedAt

  socios     Socio[]
  documentos Documento[]
  contratos  Contrato[]
  tarefas    Tarefa[]
  interacoes Interacao[]
  conversas  ConversaIA[]

  @@map("clientes")
}

model Socio {
  id           String   @id @default(uuid())
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  nome         String
  cpf          String
  qualificacao String?
  participacao Decimal? @db.Decimal(5, 2)
  email        String?
  telefone     String?
  principal    Boolean  @default(false)
  criadoEm    DateTime @default(now())

  @@map("socios")
}

model Documento {
  id         String   @id @default(uuid())
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id])
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  tipo       String
  nome       String
  url        String
  tamanho    Int?
  mimeType   String?
  status     String   @default("pendente")
  observacao String?
  criadoEm  DateTime @default(now())

  @@map("documentos")
}

model Contrato {
  id               String         @id @default(uuid())
  leadId           String         @unique
  lead             Lead           @relation(fields: [leadId], references: [id])
  clienteId        String?
  cliente          Cliente?       @relation(fields: [clienteId], references: [id])
  clicksignKey     String?        @unique
  clicksignUrl     String?
  clicksignSignUrl String?
  status           StatusContrato @default(rascunho)
  planoTipo        PlanoTipo
  valorMensal      Decimal        @db.Decimal(10, 2)
  vencimentoDia    Int
  formaPagamento   FormaPagamento
  pdfUrl           String?
  dadosSnapshot    Json?
  geradoEm        DateTime?
  enviadoEm       DateTime?
  assinadoEm      DateTime?
  expiradoEm      DateTime?
  criadoEm        DateTime       @default(now())

  @@map("contratos")
}

model Tarefa {
  id            String       @id @default(uuid())
  titulo        String
  descricao     String?      @db.Text
  clienteId     String?
  cliente       Cliente?     @relation(fields: [clienteId], references: [id])
  responsavelId String?
  responsavel   Usuario?     @relation("TarefaResponsavel", fields: [responsavelId], references: [id])
  status        StatusTarefa @default(pendente)
  prioridade    Prioridade   @default(media)
  prazo         DateTime?
  concluidaEm  DateTime?
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  @@map("tarefas")
}

model Interacao {
  id         String        @id @default(uuid())
  clienteId  String?
  cliente    Cliente?      @relation(fields: [clienteId], references: [id])
  leadId     String?
  lead       Lead?         @relation(fields: [leadId], references: [id])
  usuarioId  String?
  usuario    Usuario?      @relation(fields: [usuarioId], references: [id])
  tipo       TipoInteracao
  titulo     String?
  conteudo   String?       @db.Text
  metadados  Json?
  criadoEm  DateTime      @default(now())

  @@map("interacoes")
}

model Notificacao {
  id         String   @id @default(uuid())
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  tipo       String
  titulo     String
  mensagem   String?
  url        String?
  lida       Boolean  @default(false)
  metadados  Json?
  criadoEm  DateTime @default(now())

  @@map("notificacoes")
}

model Escritorio {
  id               String   @id @default(uuid())
  nome             String   @default("ContabAI")
  nomeFantasia     String?
  logoUrl          String?
  faviconUrl       String?
  corPrimaria      String?  @default("#6366f1")
  corSecundaria    String?  @default("#8b5cf6")
  fraseBemVindo    String?
  metaDescricao    String?
  cnpj             String?
  crc              String?
  email            String?
  telefone         String?
  whatsapp         String?
  cep              String?
  logradouro       String?
  numero           String?
  complemento      String?
  bairro           String?
  cidade           String?
  uf               String?
  clicksignKey     String?
  zapiInstanceId   String?
  zapiToken        String?
  serproCpfToken   String?
  serproCnpjToken  String?
  contratoTemplate String?  @db.Text

  // Termos contratuais configuráveis
  multaPercent                Float?  @default(2.0)
  jurosMesPercent             Float?  @default(1.0)
  diasAtrasoMulta             Int?    @default(15)
  diasInadimplenciaRescisao   Int?    @default(60)
  diasAvisoRescisao           Int?    @default(30)
  diasDocumentosAntecedencia  Int?    @default(5)
  vencimentosDias             Json?
  pixDescontoPercent          Float?  @default(5.0)

  // IA — configurações (chaves armazenadas encriptadas via AES-256-GCM)
  aiProvider        String?  @default("claude")  // "claude" | "openai"
  anthropicApiKey   String?  @db.Text
  voyageApiKey      String?  @db.Text
  openaiApiKey      String?  @db.Text
  openaiBaseUrl     String?
  openaiModel       String?
  googleApiKey      String?  @db.Text
  groqApiKey        String?  @db.Text
  aiModelOnboarding String?  @default("claude-haiku-4-5-20251001")
  aiModelCrm        String?  @default("claude-haiku-4-5-20251001")
  aiModelPortal     String?  @default("claude-haiku-4-5-20251001")
  aiModelWhatsapp   String?  @default("claude-haiku-4-5-20251001")

  aiProviderOnboarding String?  @default("claude")
  aiProviderCrm        String?  @default("claude")
  aiProviderPortal     String?  @default("claude")
  aiProviderWhatsapp   String?  @default("claude")

  // System prompts por feature (substituem o prompt padrão hardcoded)
  systemPromptOnboarding String? @db.Text
  systemPromptCrm        String? @db.Text
  systemPromptPortal     String? @db.Text

  // Email — SMTP/IMAP configuráveis (senha armazenada encriptada)
  emailRemetente   String?  // ex: contato@escritorio.com.br
  emailNome        String?  // ex: Escritório Contábil
  emailSenha       String?  @db.Text  // armazenada encriptada via crypto.ts
  emailSmtpHost    String?  // default: smtp.hostinger.com
  emailSmtpPort    Int?     // default: 587
  emailImapHost    String?  // default: imap.hostinger.com
  emailImapPort    Int?     // default: 993

  // WhatsApp AI — usa Evolution API para enviar respostas
  whatsappAiEnabled    Boolean? @default(false)
  whatsappAiFeature    String?  @default("onboarding")  // onboarding | crm | portal
  systemPromptWhatsapp String?  @db.Text
  evolutionApiUrl      String?  // ex: https://evolution.contabai.com.br
  evolutionApiKey      String?  @db.Text  // armazenada encriptada
  evolutionInstance    String?  // nome da instância

  ativo            Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@map("escritorio")
}

model ConversaIA {
  id           String       @id @default(uuid())
  canal        String       // 'whatsapp' | 'onboarding' | 'portal' | 'crm'
  clienteId    String?
  cliente      Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  leadId       String?
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  remoteJid    String?      // identificador WhatsApp
  sessionId    String?      // identificador de sessão web
  pausadaEm    DateTime?    // quando preenchido, IA não responde automaticamente
  pausadoPorId String?      // id do usuário que pausou a IA
  criadaEm     DateTime     @default(now())
  atualizadaEm DateTime     @updatedAt

  mensagens    MensagemIA[]

  @@index([remoteJid, canal])
  @@index([sessionId, canal])
  @@index([leadId, canal])
  @@index([clienteId, canal])
  @@index([atualizadaEm])
  @@map("conversas_ia")
}

model MensagemIA {
  id          String         @id @default(uuid())
  conversaId  String
  conversa    ConversaIA     @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  role        String         // 'user' | 'assistant'
  conteudo    String         @db.Text
  status      StatusMensagem @default(pending)
  tentativas  Int            @default(0)
  erroEnvio   String?        @db.Text
  criadaEm    DateTime       @default(now())

  @@index([conversaId, criadaEm])
  @@map("mensagens_ia")
}

model Escalacao {
  id               String           @id @default(uuid())
  canal            CanalEscalacao
  status           StatusEscalacao  @default(pendente)
  clienteId        String?
  leadId           String?
  remoteJid        String?          // número WA ex: 5585988765432@s.whatsapp.net
  sessionId        String?          // para onboarding widget
  historico        Json             // array de { role, content }
  ultimaMensagem   String           @db.Text
  motivoIA         String?          @db.Text
  operadorId       String?
  orientacaoHumana String?          @db.Text
  respostaEnviada  String?          @db.Text
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  @@map("escalacoes")
}
