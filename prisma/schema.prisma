generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum TipoUsuario {
  admin
  contador
  assistente
}

enum PlanoTipo {
  essencial
  profissional
  empresarial
  startup
}

enum FormaPagamento {
  pix
  boleto
  cartao
}

enum StatusLead {
  iniciado
  simulador
  plano_escolhido
  dados_preenchidos
  revisao
  contrato_gerado
  aguardando_assinatura
  assinado
  expirado
  cancelado
}

enum StatusCliente {
  ativo
  inadimplente
  suspenso
  cancelado
}

enum StatusContrato {
  rascunho
  enviado
  aguardando_assinatura
  parcialmente_assinado
  assinado
  cancelado
  expirado
}

enum Regime {
  MEI
  SimplesNacional
  LucroPresumido
  LucroReal
  Autonomo
}

enum StatusDasMEI {
  pendente
  paga
  vencida
  erro
}

enum TipoContribuinte {
  pj  // pessoa jurídica — tem empresa/CNPJ
  pf  // pessoa física — autônomo, profissional liberal
}

enum Prioridade {
  baixa
  media
  alta
  urgente
}

enum Canal {
  site
  whatsapp
  indicacao
  instagram
  google
  outro
}

enum StatusEscalacao {
  pendente
  em_atendimento
  resolvida
}

enum CanalEscalacao {
  whatsapp
  onboarding
  portal
}

enum StatusMensagem {
  pending
  sent
  failed
}

enum AsaasStatusCobranca {
  PENDING
  RECEIVED
  OVERDUE
  REFUNDED
  CANCELLED
}

enum StatusNotaFiscal {
  rascunho      // criada localmente, ainda não enviada
  enviando      // POST feito, aguardando Spedy enfileirar
  processando   // enqueued na Spedy — aguardando prefeitura
  autorizada    // autorizada pela prefeitura
  rejeitada     // rejeitada (ver erroCodigo/erroMensagem)
  cancelada     // cancelada com sucesso
  erro_interno  // falha de infra (não chegou à prefeitura)
}

model Usuario {
  id                 String      @id @default(uuid())
  nome               String
  email              String      @unique
  senhaHash          String
  tipo               TipoUsuario @default(assistente)
  ativo              Boolean     @default(true)
  precisaTrocarSenha Boolean     @default(false)
  avatar             String?
  whatsapp           String?
  criadoEm           DateTime    @default(now())
  atualizadoEm       DateTime    @updatedAt

  leadsResponsavel    Lead[]        @relation("LeadResponsavel")
  clientesResponsavel Cliente[]     @relation("ClienteResponsavel")
  interacoes          Interacao[]
  notificacoes        Notificacao[]

  // Atribuição de conversas e mensagens humanas
  conversasAtribuidas       ConversaIA[]   @relation("ConversaAtribuida")
  mensagensComoOperador     MensagemIA[]   @relation("MensagemOperador")
  interacoesAtribuidas      Interacao[]    @relation("InteracaoAtribuida")

  @@map("usuarios")
}

model Plano {
  id          String    @id @default(uuid())
  tipo        PlanoTipo @unique
  nome        String
  descricao   String?
  valorMinimo Decimal   @db.Decimal(10, 2)
  valorMaximo Decimal   @db.Decimal(10, 2)
  servicos    Json?
  destaque    Boolean   @default(false)
  ativo       Boolean   @default(true)
  criadoEm    DateTime  @default(now())

  @@map("planos")
}

model Lead {
  id             String          @id @default(uuid())
  contatoEntrada String
  canal          Canal           @default(site)
  funil          String          @default("onboarding")
  status         StatusLead      @default(iniciado)
  stepAtual      Int             @default(1)
  planoTipo      PlanoTipo?
  valorNegociado Decimal?        @db.Decimal(10, 2)
  vencimentoDia  Int?
  formaPagamento FormaPagamento?
  dadosJson      Json?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  responsavelId  String?
  responsavel    Usuario?        @relation("LeadResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  observacoes    String?         @db.Text
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt
  expiradoEm    DateTime?

  contrato   Contrato?
  documentos Documento[]
  interacoes Interacao[]
  cliente    Cliente?
  conversas  ConversaIA[]

  @@map("leads")
}

model Empresa {
  id           String        @id @default(uuid())
  cnpj         String?       @unique
  razaoSocial  String?
  nomeFantasia String?
  regime       Regime?
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  // Spedy NFS-e — credenciais por empresa (cliente é o prestador)
  spedyCompanyId          String?   @unique  // UUID da empresa na Spedy
  spedyApiKey             String?   @db.Text // encrypted — chave da empresa secundária
  spedyConfigurado        Boolean   @default(false)
  spedyConfiguradoEm      DateTime?
  // Overrides fiscais opcionais (sobrescrevem defaults do Escritorio)
  spedyFederalServiceCode String?   // código LC 116/03 ex: "1.07"
  spedyCityServiceCode    String?   // código municipal
  spedyIssAliquota        Decimal?  @db.Decimal(5, 4) // ex: 0.0500 = 5%
  spedyIssWithheld        Boolean?  // null = usar default do Escritorio
  spedyTaxationType       String?   // null = usar default do Escritorio
  // Configuração fiscal por cliente (JSON livre para overrides específicos)
  spedyConfigFiscal       Json?

  // Procuração digital RF — status cacheado (verificado via integra-procuracoes ou manualmente)
  procuracaoRFAtiva          Boolean   @default(false)
  procuracaoRFVerificadaEm   DateTime?

  clientes         Cliente[]
  socios           Socio[]
  portalTokens     PortalToken[]
  chamados         Chamado[]
  documentos       Documento[]
  notasFiscais     NotaFiscal[]
  dasMeis          DasMEI[]
  clienteEmpresas  ClienteEmpresa[]

  @@index([cnpj], name: "empresa_cnpj_partial")
  @@map("empresas")
}

model Cliente {
  id                  String          @id @default(uuid())
  leadId              String?         @unique
  lead                Lead?           @relation(fields: [leadId], references: [id])
  empresaId           String?
  empresa             Empresa?        @relation(fields: [empresaId], references: [id])
  nome                String
  cpf                 String          @unique
  rg                  String?
  dataNascimento      DateTime?
  estadoCivil         String?
  profissao           String?
  nacionalidade       String?         @default("Brasileiro(a)")
  email               String          @unique
  telefone            String
  whatsapp            String?
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?
  tipoContribuinte    TipoContribuinte @default(pj)
  planoTipo           PlanoTipo
  valorMensal         Decimal         @db.Decimal(10, 2)
  vencimentoDia       Int
  formaPagamento      FormaPagamento
  status              StatusCliente   @default(ativo)
  motivoInativacao    String?         @db.Text
  inativadoEm         DateTime?
  inativadoPorId      String?
  reativadoEm         DateTime?
  responsavelId       String?
  responsavel         Usuario?        @relation("ClienteResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)
  observacoesInternas String?         @db.Text
  tags                Json?
  dataInicio          DateTime?
  criadoEm            DateTime        @default(now())
  atualizadoEm        DateTime        @updatedAt

  portalSessionId   String?         @unique

  // Asaas — integração de cobranças
  asaasCustomerId      String?   @unique
  asaasSubscriptionId  String?   @unique
  asaasStatus          String?   // "ACTIVE" | "INACTIVE" | "OVERDUE"
  asaasUltimoSync      DateTime?

  documentos        Documento[]
  contratos         Contrato[]
  interacoes        Interacao[]
  conversas         ConversaIA[]
  portalTokens      PortalToken[]
  statusHistorico   ClienteStatusHistorico[]
  chamados          Chamado[]
  pushSubscriptions PushSubscription[]
  cobrancasAsaas    CobrancaAsaas[]
  notasFiscais      NotaFiscal[]
  comunicadoEnvios  ComunicadoEnvio[]
  dasMeis           DasMEI[]
  clienteEmpresas   ClienteEmpresa[]

  @@index([leadId], name: "cliente_leadId_partial")
  @@index([empresaId], name: "cliente_empresaId_partial")
  @@map("clientes")
}

// Tabela de junção: permite 1 cliente → N empresas
// Fase 1 da migração 1:1 → 1:N (backward-compatible com Cliente.empresaId)
model ClienteEmpresa {
  id         String   @id @default(uuid())
  clienteId  String
  empresaId  String
  principal  Boolean  @default(false)
  criadoEm   DateTime @default(now())

  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  empresa    Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([clienteId, empresaId])
  @@index([clienteId])
  @@index([empresaId])
  @@map("cliente_empresas")
}

model PushSubscription {
  id        String   @id @default(cuid())
  clienteId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  criadaEm  DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Socio {
  id           String   @id @default(uuid())
  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  nome         String
  cpf          String
  qualificacao String?
  participacao Decimal? @db.Decimal(5, 2)
  email        String?
  telefone     String?
  whatsapp     String?  // número WhatsApp dedicado (se diferente do telefone)
  principal    Boolean  @default(false)
  portalAccess    Boolean  @default(false)
  portalSessionId String?  @unique
  criadoEm        DateTime @default(now())

  portalTokens PortalToken[]
  conversas    ConversaIA[]

  @@map("socios")
}

enum TipoOS {
  duvida
  solicitacao
  reclamacao
  documento
  outros
  emissao_documento
  correcao_documento
  solicitacao_documento
  tarefa_interna
}

enum OrigemOS {
  cliente    // aberto pelo cliente via portal
  ia         // aberto pela IA em nome do cliente
  operador   // aberto internamente pelo contador/admin
}

enum CategoriaDocumento {
  geral
  nota_fiscal
  imposto_renda
  guias_tributos
  relatorios
  outros
}

enum StatusOS {
  aberta
  em_andamento
  aguardando_cliente
  resolvida
  cancelada
}

enum TipoComunicado {
  informativo
  alerta
  obrigacao
  promocional
}

model Documento {
  id             String             @id @default(uuid())
  clienteId      String?
  cliente        Cliente?           @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  leadId         String?
  lead           Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  empresaId      String?
  empresa        Empresa?           @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  ordemServicoId String?
  chamado        Chamado?           @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  tipo           String
  categoria      CategoriaDocumento @default(geral)
  nome           String
  url            String
  tamanho        BigInt?
  mimeType       String?
  status         String             @default("pendente")
  observacao     String?
  origem         String             @default("crm")
  // "crm"        = enviado pelo escritório via CRM
  // "portal"     = enviado pelo cliente via portal
  // "integracao" = empurrado por sistema externo (NFe, ERP, etc.)
  integracaoId   String?            // ex: "focus_nfe", "contaazul", "sefaz"
  xmlMetadata    Json?
  resumo         String?   @db.Text  // gerado por IA após upload
  resumoEm       DateTime?           // timestamp da última geração de resumo
  resumoStatus     String    @default("pendente")   // pendente|ok|falhou|esgotado
  resumoTentativas Int       @default(0)
  resumoErro       String?   @db.Text
  visivelPortal  Boolean            @default(true)   // false = doc interno, não aparece no portal
  dataVencimento          DateTime?           // null = sem vencimento (guias, certidões, procurações)
  lembrete5dEnviadoEm     DateTime?           // lembrete 5 dias antes enviado em
  lembreteDiaEnviadoEm    DateTime?           // lembrete no dia do vencimento enviado em
  visualizadoEm  DateTime?           // null = não visualizado pelo cliente (origem 'crm')
  deletadoEm     DateTime?
  criadoEm       DateTime           @default(now())

  @@index([clienteId, criadoEm])
  @@index([empresaId, criadoEm])
  @@index([clienteId, deletadoEm])
  @@index([dataVencimento, deletadoEm])
  @@map("documentos")
}

model Chamado {
  id              String    @id @default(uuid())
  numero          Int       @default(autoincrement()) @unique
  clienteId       String
  cliente         Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  empresaId       String?
  empresa         Empresa?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  tipo            TipoOS     @default(duvida)
  origem          OrigemOS   @default(cliente)
  visivelPortal   Boolean    @default(true)
  titulo          String
  descricao       String    @db.Text
  status          StatusOS  @default(aberta)
  prioridade      Prioridade @default(media)
  resposta        String?   @db.Text
  respondidoEm    DateTime?
  respondidoPorId String?
  avaliacaoNota   Int?
  avaliacaoComent String?
  avaliadoEm      DateTime?
  fechadoEm       DateTime?
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  documentos   Documento[]
  notasFiscais NotaFiscal[]
  notas        ChamadoNota[]

  @@index([clienteId, criadoEm])
  @@index([status, criadoEm])
  @@index([numero])
  @@map("ordens_servico")
}

model ChamadoNota {
  id        String   @id @default(uuid())
  chamadoId String
  chamado   Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  conteudo  String   @db.Text
  autorId   String?
  criadoEm  DateTime @default(now())

  @@index([chamadoId, criadoEm])
  @@map("chamado_notas")
}

model Comunicado {
  id             String         @id @default(uuid())
  titulo         String
  conteudo       String         @db.Text
  tipo           TipoComunicado @default(informativo)
  publicado      Boolean        @default(false)
  publicadoEm    DateTime?
  expiradoEm     DateTime?
  emailEnviadoEm DateTime?
  anexoUrl       String?   // URL pública do arquivo no storage
  anexoNome      String?   // nome original do arquivo
  criadoPorId    String?
  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  envios         ComunicadoEnvio[]

  @@index([publicado, publicadoEm])
  @@index([criadoEm])
  @@map("comunicados")
}

model ComunicadoEnvio {
  id           String    @id @default(uuid())
  comunicadoId String
  comunicado   Comunicado @relation(fields: [comunicadoId], references: [id], onDelete: Cascade)
  clienteId    String
  cliente      Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  email        String
  status       String    @default("pendente")  // "pendente" | "enviado" | "falhou"
  erro         String?
  enviadoEm    DateTime?
  criadoEm     DateTime  @default(now())

  @@unique([comunicadoId, clienteId])
  @@index([comunicadoId])
  @@map("comunicado_envios")
}

model Contrato {
  id               String         @id @default(uuid())
  leadId           String         @unique
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clienteId        String?
  cliente          Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clicksignKey     String?  @unique
  clicksignUrl     String?
  clicksignSignUrl String?
  zapsignDocToken  String?  @unique
  zapsignSignUrl   String?
  status               StatusContrato @default(rascunho)
  planoTipo        PlanoTipo
  valorMensal      Decimal        @db.Decimal(10, 2)
  vencimentoDia    Int
  formaPagamento   FormaPagamento
  pdfUrl           String?
  dadosSnapshot    Json?
  geradoEm        DateTime?
  enviadoEm       DateTime?
  assinadoEm      DateTime?
  expiradoEm      DateTime?
  deletadoEm      DateTime?
  criadoEm        DateTime       @default(now())

  @@index([clienteId, deletadoEm])
  @@map("contratos")
}

model Interacao {
  id               String   @id @default(uuid())
  clienteId        String?
  cliente          Cliente? @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  leadId           String?
  lead             Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  usuarioId        String?
  usuario          Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  tipo             String   // string livre — veja TipoEvento em src/lib/historico.ts
  origem           String   @default("sistema") // "usuario" | "ia" | "agente" | "sistema"
  escritorioEvento Boolean  @default(false)      // aparece no feed global do dashboard
  titulo           String?
  conteudo         String?  @db.Text
  metadados        Json?
  // E-mail: rastreia se o email_recebido foi respondido ou dispensado
  respondidoEm     DateTime?
  respondidoPorId  String?
  // Atribuição: operador responsável por responder este email/thread
  atribuidaParaId  String?
  atribuidaPara    Usuario?  @relation("InteracaoAtribuida", fields: [atribuidaParaId], references: [id], onDelete: SetNull)
  atribuidaEm      DateTime?
  deletadoEm       DateTime?
  criadoEm         DateTime @default(now())
  // Threading de e-mail — agrupa mensagens da mesma conversa
  emailMessageId  String?   // Message-ID header deste e-mail
  emailInReplyTo  String?   // In-Reply-To header (aponta para o email anterior)
  emailThreadId   String?   // Root Message-ID da conversa (igual em todos da mesma thread)

  @@index([clienteId, criadoEm])
  @@index([leadId, criadoEm])
  @@index([origem, criadoEm])
  @@index([escritorioEvento, criadoEm])
  @@index([tipo, criadoEm])
  @@index([tipo, respondidoEm])
  @@index([clienteId, deletadoEm])
  @@index([emailThreadId, criadoEm])
  @@index([emailMessageId])
  @@index([atribuidaParaId])
  @@map("interacoes")
}

model Notificacao {
  id         String   @id @default(uuid())
  usuarioId  String
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tipo       String
  titulo     String
  mensagem   String?
  url        String?
  lida       Boolean  @default(false)
  metadados  Json?
  criadoEm  DateTime @default(now())

  @@map("notificacoes")
}

model Escritorio {
  id               String   @id @default(uuid())
  nome             String   @default("ContabAI")
  nomeFantasia     String?
  logoUrl          String?
  faviconUrl       String?
  corPrimaria      String?  @default("#6366f1")
  corSecundaria    String?  @default("#8b5cf6")
  fraseBemVindo    String?
  metaDescricao    String?
  cnpj             String?
  crc              String?
  email            String?
  telefone         String?
  whatsapp         String?
  cep              String?
  logradouro       String?
  numero           String?
  complemento      String?
  bairro           String?
  cidade           String?
  uf               String?
  // Assinatura eletrônica
  provedorAssinatura   String?  @default("zapsign")  // "zapsign" | "clicksign"
  zapsignToken         String?  @db.Text              // encriptado
  clicksignKey         String?                        // encriptado
  clicksignHmacSecret  String?                        // HMAC SHA256 secret (plain — não é chave de acesso)
  zapsignWebhookSecret String?                        // secret token para validar webhook ZapSign (?secret=xxx na URL)

  zapiInstanceId   String?
  zapiToken        String?
  serproCpfToken   String?
  serproCnpjToken  String?
  contratoTemplate String?  @db.Text

  // Termos contratuais configuráveis
  multaPercent                Float?  @default(2.0)
  jurosMesPercent             Float?  @default(1.0)
  diasAtrasoMulta             Int?    @default(15)
  diasInadimplenciaRescisao   Int?    @default(60)
  diasAvisoRescisao           Int?    @default(30)
  diasDocumentosAntecedencia  Int?    @default(5)
  vencimentosDias             Json?
  pixDescontoPercent          Float?  @default(5.0)

  // IA — configurações (chaves armazenadas encriptadas via AES-256-GCM)
  aiProvider        String?  @default("claude")  // "claude" | "openai"
  anthropicApiKey   String?  @db.Text
  voyageApiKey      String?  @db.Text
  openaiApiKey      String?  @db.Text
  openaiBaseUrl     String?
  openaiModel       String?
  googleApiKey      String?  @db.Text
  groqApiKey        String?  @db.Text
  aiModelOnboarding String?  @default("claude-haiku-4-5-20251001")
  aiModelCrm        String?  @default("claude-haiku-4-5-20251001")
  aiModelPortal     String?  @default("claude-haiku-4-5-20251001")
  aiModelWhatsapp   String?  @default("claude-haiku-4-5-20251001")
  aiModelAgente     String?  @default("claude-haiku-4-5-20251001")

  aiProviderOnboarding      String?  @default("claude")
  aiProviderCrm             String?  @default("claude")
  aiProviderPortal          String?  @default("claude")
  aiProviderWhatsapp        String?  @default("claude")
  aiProviderAgente          String?  @default("claude")
  aiModelDocumentoResumo    String?  @default("claude-haiku-4-5-20251001")
  aiProviderDocumentoResumo String?  @default("claude")

  // Nome de cada IA por feature (cada uma pode ter identidade própria)
  nomeAssistenteOnboarding String?
  nomeAssistenteCrm        String?
  nomeAssistentePortal     String?
  nomeAssistenteWhatsapp   String?

  // System prompts por feature (substituem o prompt padrão hardcoded)
  systemPromptOnboarding String? @db.Text
  systemPromptCrm        String? @db.Text
  systemPromptPortal     String? @db.Text

  // Agente Operacional — tools desabilitadas pelo admin (array de nomes de tools)
  toolsDesabilitadas     Json?   // string[] — ex: ["enviarEmail", "criarLead"]
  // Agente Operacional — canais disponíveis por tool (substitui o padrão do meta)
  toolsCanaisOverride    Json?   // Record<string, string[]> — ex: {"enviarEmail": ["crm"]}
  // Permissões de menu por perfil (null = usar defaults hardcoded em menu-permissoes.ts)
  menuPermissoes         Json?   // { contador: string[], assistente: string[] }

  // Email — SMTP/IMAP configuráveis (senha armazenada encriptada)
  emailRemetente   String?  // ex: contato@escritorio.com.br
  emailNome        String?  // ex: Escritório Contábil
  emailSenha       String?  @db.Text  // armazenada encriptada via crypto.ts
  emailSmtpHost    String?  // default: smtp.hostinger.com
  emailSmtpPort    Int?     // default: 587
  emailImapHost    String?  // default: imap.hostinger.com
  emailImapPort    Int?     // default: 993

  // Estratégia de entrega de documentos via WhatsApp
  // "direto"      = envia URL pública direta
  // "senha"       = aplica senha (PDF via qpdf, OFX/XLS via 7z) — requer config adicional
  // "link_portal" = envia link autenticado do portal
  whatsappDocumentoEntrega String @default("direto")

  // Asaas — integração de cobranças
  asaasApiKey          String?  @db.Text   // encriptado (mesmo padrão das chaves AI)
  asaasAmbiente        String?  @default("sandbox")  // "sandbox" | "production"
  asaasWebhookToken    String?             // token para validar webhooks recebidos

  // Spedy NFS-e — conta Owner do escritório (gerencia empresas secundárias dos clientes)
  spedyApiKey             String?  @db.Text   // encrypted — Owner key
  spedyAmbiente           String?  @default("sandbox") // "sandbox" | "producao"
  spedyWebhookId          String?             // UUID do webhook registrado na Spedy
  // Defaults fiscais (usados quando a Empresa do cliente não tem override)
  spedyFederalServiceCode String?             // código LC 116/03 padrão ex: "1.07"
  spedyCityServiceCode    String?             // código municipal padrão
  spedyIssAliquota        Decimal? @db.Decimal(5, 4)  // ex: 0.0500 = 5%
  spedyTaxationType       String?  @default("taxationInMunicipality")
  spedyIssWithheld        Boolean  @default(false)
  // Automações
  spedyAutoEmitirOS       Boolean  @default(false) // auto-emitir ao resolver OS
  spedyEnviarAoAutorizar  Boolean  @default(true)  // enviar PDF ao cliente após autorização
  spedyEnviarCanalPadrao  String?  @default("whatsapp") // "whatsapp" | "email" | "portal"
  spedyDescricaoTemplate  String?  @db.Text        // template com variáveis {{os.numero}} etc.

  // WhatsApp AI — usa Evolution API para enviar respostas
  whatsappAiEnabled    Boolean? @default(false)
  whatsappAiFeature    String?  @default("onboarding")  // onboarding | crm | portal
  systemPromptWhatsapp String?  @db.Text
  evolutionApiUrl      String?  // ex: https://evolution.contabai.com.br
  evolutionApiKey      String?  @db.Text  // armazenada encriptada
  evolutionInstance    String?  // nome da instância

  // Integra Contador (SERPRO) — acesso a serviços da Receita Federal via API
  // Requer contrato com SERPRO + procuração digital concedida por cada cliente via e-CAC
  integraContadorClientId     String?             // consumer key do contrato SERPRO
  integraContadorClientSecret String? @db.Text    // consumer secret — ENCRYPTED
  integraContadorAmbiente     String? @default("homologacao") // "homologacao" | "producao"
  integraContadorCertBase64   String? @db.Text    // certificado e-CNPJ do escritório (.pfx em base64) — ENCRYPTED
  integraContadorCertSenha    String? @db.Text    // senha do certificado — ENCRYPTED
  integraContadorEnabled      Boolean @default(false)
  integraContadorModulos      String? @default("[]") // JSON array: ["integra-sn","integra-mei","integra-sitfis","integra-pagamento",...]

  // DAS MEI — configurações de automação
  dasMeiVencimentoDia       Int     @default(20)   // dia do mês do vencimento da DAS
  dasMeiDiasAntecedencia    Int     @default(5)    // dias antes do vencimento para gerar a DAS
  dasMeiCanalEmail          Boolean @default(true)
  dasMeiCanalWhatsapp       Boolean @default(true)
  dasMeiCanalPwa            Boolean @default(true)

  ativo            Boolean  @default(true)
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@map("escritorio")
}

model ConversaIA {
  id           String       @id @default(uuid())
  canal        String       // 'whatsapp' | 'onboarding' | 'portal' | 'crm'
  clienteId    String?
  cliente      Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  leadId       String?
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  socioId      String?      // sócio que iniciou/recebeu a conversa (opcional)
  socio        Socio?       @relation(fields: [socioId], references: [id], onDelete: SetNull)
  remoteJid    String?      // identificador WhatsApp
  sessionId    String?      // identificador de sessão web
  pausadaEm        DateTime?    // quando preenchido, IA não responde automaticamente
  pausadoPorId     String?      // id do usuário que pausou a IA
  atribuidaParaId  String?      // operador responsável pela conversa (null = não atribuída)
  atribuidaPara    Usuario?     @relation("ConversaAtribuida", fields: [atribuidaParaId], references: [id], onDelete: SetNull)
  atribuidaEm      DateTime?    // quando foi atribuída
  ultimaMensagemEm DateTime?    // atualizado a cada msg recebida (debounce WhatsApp)
  processandoEm   DateTime?    // lock distribuído: cron seta ao iniciar, limpa no finally; evita duplo processamento entre instâncias
  criadaEm         DateTime     @default(now())
  atualizadaEm     DateTime     @updatedAt

  mensagens    MensagemIA[]

  @@index([remoteJid, canal])
  @@index([sessionId, canal])
  @@index([leadId, canal])
  @@index([clienteId, canal])
  @@index([socioId, canal])
  @@index([atualizadaEm])
  @@index([canal, atualizadaEm])
  @@index([pausadaEm])
  @@index([atribuidaParaId])
  @@map("conversas_ia")
}

model MensagemIA {
  id                String         @id @default(uuid())
  conversaId        String
  conversa          ConversaIA     @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  role              String         // 'user' | 'assistant'
  operadorId        String?        // null = mensagem da IA; preenchido = operador humano que enviou
  operador          Usuario?       @relation("MensagemOperador", fields: [operadorId], references: [id], onDelete: SetNull)
  conteudo          String         @db.Text
  status            StatusMensagem @default(pending)
  tentativas        Int            @default(0)
  erroEnvio         String?        @db.Text
  aiProcessado      Boolean        @default(true)  // false = aguardando processamento (debounce WhatsApp)
  whatsappMsgData   Json?          // payload { key, message } para re-fetch de mídia na Evolution
  mediaBuffer       Bytes?         // conteúdo binário da mídia recebida via WhatsApp (evita re-fetch após expiração da URL)
  // Mídia enviada pelo operador via chat CRM
  mediaUrl          String?        // URL pública do arquivo (S3)
  mediaType         String?        // 'image' | 'document' | 'audio'
  mediaFileName     String?        // nome original do arquivo
  mediaMimeType     String?        // ex: application/pdf, image/jpeg
  excluido          Boolean        @default(false)  // soft delete — operador apagou para todos
  excluidoEm        DateTime?
  criadaEm          DateTime       @default(now())

  @@index([conversaId, criadaEm])
  @@map("mensagens_ia")
}

model Escalacao {
  id               String           @id @default(uuid())
  canal            CanalEscalacao
  status           StatusEscalacao  @default(pendente)
  clienteId        String?
  leadId           String?
  conversaIAId     String?          // referência à ConversaIA (quando disponível)
  remoteJid        String?          // número WA ex: 5585988765432@s.whatsapp.net
  sessionId        String?          // para onboarding widget
  historico        Json             // array de { role, content }
  ultimaMensagem   String           @db.Text
  motivoIA         String?          @db.Text
  operadorId       String?
  orientacaoHumana String?          @db.Text
  respostaEnviada  String?          @db.Text
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt

  @@map("escalacoes")
}

model PortalToken {
  id         String    @id @default(uuid())
  empresaId  String
  empresa    Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  socioId    String?
  socio      Socio?    @relation(fields: [socioId], references: [id], onDelete: Cascade)
  token      String    @unique  // hash SHA-256 do token enviado por e-mail
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime? // para invalidação no logout
  otp        String?   // hash SHA-256 do código OTP de 6 dígitos
  otpExpiresAt DateTime? // expiração do OTP (independente do link)
  criadoEm   DateTime  @default(now())

  @@index([empresaId])
  @@index([clienteId])
  @@index([socioId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([clienteId, usedAt])
  @@map("portal_tokens")
}

model ClienteStatusHistorico {
  id           String        @id @default(uuid())
  clienteId    String
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  statusAntes  StatusCliente
  statusDepois StatusCliente
  motivo       String?       @db.Text
  operadorId   String?
  operadorNome String?
  criadoEm     DateTime      @default(now())

  @@index([clienteId, criadoEm])
  @@map("cliente_status_historico")
}

model AgenteAcao {
  id            String   @id @default(uuid())
  clienteId     String?
  leadId        String?
  solicitanteAI String   // 'crm' | 'whatsapp' | 'portal' | 'onboarding'
  usuarioId     String?  // ID do usuário CRM que acionou (null para ações automáticas)
  usuarioNome   String?  // Nome legível para o log
  usuarioTipo   String?  // 'admin' | 'contador' | 'atendente'
  tool          String   // nome da ferramenta executada
  input         Json     // parâmetros passados para a ferramenta
  resultado     Json     // { sucesso, resumo, erro, dados }
  sucesso       Boolean
  duracaoMs     Int
  criadoEm     DateTime @default(now())

  @@index([clienteId, criadoEm])
  @@index([leadId, criadoEm])
  @@index([tool, criadoEm])
  @@index([usuarioId, criadoEm])
  @@map("agente_acoes")
}

model AgendamentoAgente {
  id              String    @id @default(uuid())
  descricao       String    // "Relatório semanal de funil toda segunda"
  cron            String    // expressão cron: "0 8 * * 1"
  instrucao       String    // instrução em linguagem natural para executarAgente
  ativo           Boolean   @default(true)
  criadoPorId     String?   // usuarioId de quem criou
  criadoPorNome   String?   // nome legível
  ultimoDisparo   DateTime?
  proximoDisparo  DateTime? // pré-calculado para facilitar query
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  @@index([ativo, proximoDisparo])
  @@map("agendamentos_agente")
}

model RelatorioAgente {
  id              String    @id @default(uuid())
  titulo          String
  conteudo        String    // conteúdo markdown completo
  tipo            String    // 'agendado' | 'manual'
  sucesso         Boolean   @default(true)
  agendamentoId   String?   // FK lógica (sem constraint — agendamento pode ser deletado)
  agendamentoDesc String?   // cópia da descrição do agendamento no momento da execução
  criadoPorId     String?
  criadoPorNome   String?
  arquivoUrl      String?   // URL S3 se arquivo foi gerado
  arquivoNome     String?
  criadoEm        DateTime  @default(now())

  @@index([tipo, criadoEm])
  @@index([criadoPorId, criadoEm])
  @@map("relatorios_agente")
}

model NotaFiscal {
  id             String           @id @default(uuid())
  clienteId      String
  cliente        Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  empresaId      String?
  empresa        Empresa?         @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  ordemServicoId String?
  chamado        Chamado?         @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  emitidaPorId         String?  // usuarioId — null = agente/automático
  solicitadaPeloPortal Boolean  @default(false) // true = originada pelo cliente no portal

  // IDs Spedy
  spedyId        String?          @unique  // UUID retornado pela Spedy
  integrationId  String?          @unique  // nosso ID enviado (ordemServicoId ou gerado)

  // Status
  status         StatusNotaFiscal @default(rascunho)
  numero         Int?             // atribuído pela prefeitura ao autorizar
  rpsNumero      Int?
  rpsSerie       String?

  // Dados fiscais — o que foi enviado à Spedy
  descricao      String           @db.Text
  valorTotal     Decimal          @db.Decimal(10, 2)
  issRetido      Boolean          @default(false)
  issAliquota    Decimal?         @db.Decimal(5, 4)
  issValor       Decimal?         @db.Decimal(10, 2)
  pisAliquota    Decimal?         @db.Decimal(5, 4)
  pisValor       Decimal?         @db.Decimal(10, 2)
  cofinsAliquota Decimal?         @db.Decimal(5, 4)
  cofinsValor    Decimal?         @db.Decimal(10, 2)
  irAliquota     Decimal?         @db.Decimal(5, 4)
  irValor        Decimal?         @db.Decimal(10, 2)
  valorLiquido   Decimal?         @db.Decimal(10, 2)

  // Código fiscal utilizado
  federalServiceCode String?
  cityServiceCode    String?
  taxationType       String?

  // Tomador (quem está recebendo a nota do cliente)
  tomadorNome        String?
  tomadorCpfCnpj     String?
  tomadorEmail       String?
  tomadorMunicipio   String?
  tomadorEstado      String?

  // Autorização
  xmlUrl         String?
  pdfUrl         String?
  chaveAcesso    String?
  protocolo      String?
  autorizadaEm   DateTime?

  // Cancelamento
  canceladaEm                   DateTime?
  cancelamentoJustificativa     String?

  // Rastreamento de erros
  erroCodigo     String?
  erroMensagem   String?          @db.Text
  tentativas     Int              @default(0)

  // Entrega ao cliente
  enviadaClienteEm    DateTime?
  enviadaClienteCanal String?   // "whatsapp" | "email" | "portal"

  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@index([clienteId, criadoEm])
  @@index([empresaId, criadoEm])
  @@index([status, criadoEm])
  @@index([ordemServicoId])
  @@index([spedyId])
  @@index([clienteId, status])
  @@map("notas_fiscais")
}

model CobrancaAsaas {
  id              String               @id @default(cuid())
  asaasId         String               @unique    // payment.id retornado pelo Asaas
  clienteId       String
  cliente         Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  valor           Decimal              @db.Decimal(10, 2)
  vencimento      DateTime
  status          AsaasStatusCobranca  @default(PENDING)
  formaPagamento  FormaPagamento       // pix | boleto

  // Boleto
  linkBoleto      String?
  codigoBarras    String?

  // PIX
  pixQrCode       String?              @db.Text   // base64 da imagem QR
  pixCopiaECola   String?              @db.Text   // payload EMV

  // Comprovante público (Asaas invoiceUrl — válido para PIX e boleto)
  invoiceUrl      String?

  // Confirmação de pagamento
  pagoEm          DateTime?
  valorPago       Decimal?             @db.Decimal(10, 2)

  // Controle de lembrete D-3
  lembreteEnviado Boolean              @default(false)

  // Rastreia quando o QR Code/payload PIX foi gerado pela última vez.
  // atualizadoEm é resetado por qualquer webhook — este campo só muda quando
  // o PIX chega do Asaas, permitindo calcular expiração com precisão.
  pixGeradoEm     DateTime?

  criadoEm        DateTime             @default(now())
  atualizadoEm    DateTime             @updatedAt

  @@index([clienteId])
  @@index([vencimento])
  @@index([status])
  @@index([clienteId, status])
  @@index([status, vencimento, lembreteEnviado])
  @@map("cobrancas_asaas")
}

model WebhookLog {
  id         String   @id @default(uuid())
  provider   String   // "zapsign" | "clicksign" | "docuseal"
  eventId    String   // token/id único do evento
  processado Boolean  @default(false)
  payload    Json?
  criadoEm   DateTime @default(now())

  @@unique([provider, eventId])
  @@index([criadoEm])
  @@map("webhook_logs")
}

model DasMEI {
  id              String       @id @default(uuid())
  empresaId       String
  empresa         Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  clienteId       String
  cliente         Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  competencia     String       // "AAAAMM" ex: "202601" = janeiro/2026
  codigoBarras    String?      @db.Text
  valor           Decimal?     @db.Decimal(10, 2)
  dataVencimento  DateTime?
  urlDas          String?      @db.Text
  status          StatusDasMEI @default(pendente)
  erroMsg         String?      @db.Text
  notificadoEm    DateTime?    // quando enviou notificação "DAS disponível"
  lembreteEnviadoEm DateTime?  // quando enviou lembrete de vencimento
  raw             Json?        // resposta bruta do SERPRO
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt

  @@unique([empresaId, competencia])
  @@index([competencia])
  @@index([status])
  @@index([clienteId])
  @@index([dataVencimento, status])
  @@map("das_mei")
}
