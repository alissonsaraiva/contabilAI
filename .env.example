# ─── Banco de Dados ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/contabil_ia"
# Banco pgvector (pode ser o mesmo que DATABASE_URL se tiver a extensão instalada)
# Rodar scripts/init-vectors.sql uma vez antes de usar a base de conhecimento
VECTORS_DATABASE_URL="postgresql://user:password@host:5432/contabil_ia"

# ─── NextAuth ──────────────────────────────────────────────────
AUTH_SECRET="gere com: openssl rand -base64 32"
AUTH_URL="https://contabai.com.br"

# ─── IA ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Storage (S3 / Cloudflare R2) ──────────────────────────────
STORAGE_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="contabai"
STORAGE_PUBLIC_URL="https://storage.contabai.com.br"
STORAGE_REGION="auto"

# ─── Integrações ───────────────────────────────────────────────
CLICKSIGN_API_KEY=""
CLICKSIGN_ESCRITORIO_EMAIL=""
CLICKSIGN_ESCRITORIO_NOME=""
SERPRO_CPF_TOKEN=""
SERPRO_CNPJ_TOKEN=""
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""

# ─── n8n ───────────────────────────────────────────────────────
N8N_WEBHOOK_SECRET=""
N8N_BASE_URL=""

# ─── Monitoramento ─────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ─── Email (Hostinger SMTP/IMAP) ───────────────────────────────
# Alternativa às configurações no banco (CRM → Configurações → Contato)
EMAIL_REMETENTE="contato@escritorio.com.br"
EMAIL_SENHA=""
EMAIL_NOME="Escritório Contábil"

# ─── Cron ──────────────────────────────────────────────────────
# Protege o endpoint POST /api/email/sync chamado pelo scheduler
CRON_SECRET="gere com: openssl rand -base64 32"

# ─── App ───────────────────────────────────────────────────────
# Domínio raiz (onboarding / site público)
NEXT_PUBLIC_APP_URL="https://avos.digital"
NEXT_PUBLIC_APP_NAME="Avós Digital"

# Subdomínios — usados pelo proxy.ts para isolamento e pelos magic links
NEXT_PUBLIC_CRM_URL="https://crm.avos.digital"
NEXT_PUBLIC_PORTAL_URL="https://portal.avos.digital"
