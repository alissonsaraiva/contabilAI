# ─── Banco de Dados ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/contabil_ia"
# Banco pgvector (pode ser o mesmo que DATABASE_URL se tiver a extensão instalada)
# Rodar scripts/init-vectors.sql uma vez antes de usar a base de conhecimento
VECTORS_DATABASE_URL="postgresql://user:password@host:5432/contabil_ia"

# ─── NextAuth ──────────────────────────────────────────────────
AUTH_SECRET="gere com: openssl rand -base64 32"
AUTH_URL="https://contabai.com.br"

# ─── IA ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Storage (S3 / Cloudflare R2) ──────────────────────────────
STORAGE_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="contabai"
STORAGE_PUBLIC_URL="https://storage.contabai.com.br"
STORAGE_REGION="auto"

# ─── Integrações ───────────────────────────────────────────────
